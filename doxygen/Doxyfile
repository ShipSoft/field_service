PROJECT_NAME           = "SHiP Field Service"
PROJECT_BRIEF          = "Framework-agnostic C++20 library exposing SHiP magnetic field maps."
OUTPUT_DIRECTORY       = doxygen
INPUT                  = include src
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HAVE_DOT               = YES
QUIET                  = YES
WARN_NO_PARAMDOC       = NO
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                 += README.md
JAVADOC_AUTOBRIEF      = YES
